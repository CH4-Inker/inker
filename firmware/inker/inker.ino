  epd_bitmap_backward2,
  epd_bitmap_backward3,
  epd_bitmap_backward4,
  epd_bitmap_backward5,
  epd_bitmap_backward6
};

// Pause animation frame list (circle morphs into pause bars)
#define PAUSE_FRAMES 3
const unsigned char* pauseFrames[PAUSE_FRAMES] = {
  epd_bitmap_pause1,
  epd_bitmap_pause2,
  epd_bitmap_pause3
};

