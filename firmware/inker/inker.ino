};

// Playing (song-running) animation frame list — replaces idle eyes while playing
#define PLAYING_FRAMES 8
const unsigned char* playingFrames[PLAYING_FRAMES] = {
  epd_bitmap_music_playing1,
  epd_bitmap_music_playing2,
  epd_bitmap_music_playing3,
  epd_bitmap_music_playing4,
  epd_bitmap_music_playing5,
